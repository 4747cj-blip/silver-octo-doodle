{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nBL = Motor(Ports.PORT8, GearSetting.RATIO_18_1, False)\nFL = Motor(Ports.PORT9, GearSetting.RATIO_18_1, False)\nFR = Motor(Ports.PORT11, GearSetting.RATIO_18_1, True)\nBR = Motor(Ports.PORT14, GearSetting.RATIO_18_1, True)\ninertial_1 = Inertial(Ports.PORT1)\ncontroller_1 = Controller(PRIMARY)\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\n\nmyVariable = 0\nIs_calibrated = False\nIsRobotCentric = False\n\ndef ArcadeCode():\n    global myVariable, Is_calibrated, IsRobotCentric\n    BL.set_velocity((1 * controller_1.axis3.position() + -1 * controller_1.axis1.position()), PERCENT)\n    FL.set_velocity((1 * controller_1.axis3.position() + 1 * controller_1.axis1.position()), PERCENT)\n    FR.set_velocity((1 * controller_1.axis3.position() + -1 * controller_1.axis1.position()), PERCENT)\n    BR.set_velocity((1 * controller_1.axis3.position() + 1 * controller_1.axis1.position()), PERCENT)\n\ndef RightTurn():\n    global myVariable, Is_calibrated, IsRobotCentric\n    BL.set_velocity(100, PERCENT)\n    FL.set_velocity(100, PERCENT)\n    FR.set_velocity(-100, PERCENT)\n    BR.set_velocity(-100, PERCENT)\n\ndef LeftTurn():\n    global myVariable, Is_calibrated, IsRobotCentric\n    BL.set_velocity(-100, PERCENT)\n    FL.set_velocity(-100, PERCENT)\n    FR.set_velocity(100, PERCENT)\n    BR.set_velocity(100, PERCENT)\n\ndef FieldCentricCode():\n    global myVariable, Is_calibrated, IsRobotCentric\n    FL.set_velocity(((math.cos(inertial_1.heading(DEGREES)/180.0*math.pi) * controller_1.axis3.position()) + (math.sin(inertial_1.heading(DEGREES)/180.0*math.pi) * controller_1.axis1.position())) + ((math.cos(inertial_1.heading (DEGREES)/180.0*math.pi) * controller_1.axis3.position) - (math.sin(inertial_1.heading(DEGREES)/180.0*math.pi)*controller_1.axis1.position)), PERCENT)\n    BR.set_velocity(((math.cos(inertial_1.heading(DEGREES)/180.0*math.pi) * controller_1.axis3.position()) + (math.sin(inertial_1.heading(DEGREES)/180.0*math.pi) * controller_1.axis1.position())) + ((math.cos(inertial_1.heading (DEGREES)/180.0*math.pi) * controller_1.axis3.position) - (math.sin(inertial_1.heading(DEGREES)/180.0*math.pi)*controller_1.axis1.position)), PERCENT)\n    BL.set_velocity(((math.cos(inertial_1.heading(DEGREES)/180.0*math.pi) * controller_1.axis3.position()) + (math.sin(inertial_1.heading(DEGREES)/180.0*math.pi) * controller_1.axis1.position())) - ((math.cos(inertial_1.heading (DEGREES)/180.0*math.pi) * controller_1.axis3.position) - (math.sin(inertial_1.heading(DEGREES)/180.0*math.pi)*controller_1.axis1.position)), PERCENT)\n    FR.set_velocity(((math.cos(inertial_1.heading(DEGREES)/180.0*math.pi) * controller_1.axis3.position()) + (math.sin(inertial_1.heading(DEGREES)/180.0*math.pi) * controller_1.axis1.position())) - ((math.cos(inertial_1.heading (DEGREES)/180.0*math.pi) * controller_1.axis3.position) - (math.sin(inertial_1.heading(DEGREES)/180.0*math.pi)*controller_1.axis1.position)), PERCENT)\ndef when_started1():   \n    global myVariable, Is_calibrated, IsRobotCentric\n    Is_calibrated = False\n    IsRobotCentric = False\n    inertial_1.calibrate()\n    while inertial_1.is_calibrating():\n        sleep(50)\n    Is_calibrated = True\n\ndef when_started2():\n    global myVariable, Is_calibrated, IsRobotCentric\n    BL.spin(FORWARD)\n    FL.spin(FORWARD)\n    FR.spin(FORWARD)\n    BR.spin(FORWARD)\n    BL.set_velocity(0, PERCENT)\n    FL.set_velocity(0, PERCENT)\n    FR.set_velocity(0, PERCENT)\n    BR.set_velocity(0, PERCENT)\n\ndef when_started3():\n    global myVariable, Is_calibrated, IsRobotCentric\n    while not Is_calibrated:\n        wait(5, MSEC)\n    while True:\n        if controller_1.buttonR1.pressing():\n            RightTurn()\n        elif controller_1.buttonL1.pressing():\n            LeftTurn()\n        else:\n            if IsRobotCentric:\n                ArcadeCode()\n            else:\n                FieldCentricCode()\n            wait(0.005, SECONDS)\n        wait(5, MSEC)\n\ndef controller_1buttonR2_pressed_callback_0():\n    global myVariable, Is_calibrated, IsRobotCentric\n    inertial_1.set_heading(0, DEGREES)\n\ndef controller_1buttonL2_pressed_callback_0():\n    global myVariable, Is_calibrated, IsRobotCentric\n    if not IsRobotCentric:\n        IsRobotCentric = True\n    else:\n        IsRobotCentric = False\n\n# system event handlers\ncontroller_1.buttonR2.pressed(controller_1buttonR2_pressed_callback_0)\ncontroller_1.buttonL2.pressed(controller_1buttonL2_pressed_callback_0)\n# add 15ms delay to make sure events are registered correctly.\nwait(15, MSEC)\n\nws2 = Thread( when_started2 )\nws3 = Thread( when_started3 )\nwhen_started1()\n","textLanguage":"python","robotConfig":[{"port":[8],"name":"BL","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[9],"name":"FL","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[11],"name":"FR","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[14],"name":"BR","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[1],"name":"inertial_1","customName":false,"deviceType":"Inertial","deviceClass":"inertial","setting":{},"triportSourcePort":22},{"port":[],"name":"controller_1","customName":false,"deviceType":"Controller","deviceClass":"controller","setting":{"left":"","leftDir":"false","right":"","rightDir":"false","upDown":"","upDownDir":"false","xB":"","xBDir":"false","drive":"none","id":"primary"},"triportSourcePort":22}],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.67.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}